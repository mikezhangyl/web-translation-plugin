{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Harness Scenario",
  "type": "object",
  "required": ["id", "description", "mode", "fixture"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["dry-run"]
    },
    "fixture": {
      "type": "object",
      "required": ["inputPath", "expectedOutputPath"],
      "properties": {
        "inputPath": {
          "type": "string",
          "minLength": 1
        },
        "expectedOutputPath": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
