{
  "name": "vibe-coding-os-translation-plugin",
  "displayName": "Vibe coding os translation plugin",
  "version": "0.0.1",
  "description": "A basic Plasmo extension.",
  "author": "Plasmo Corp. <foss@plasmo.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test:ui-logic": "tsx --test tests/*.test.ts",
    "test:e2e": "npm run build && playwright test",
    "check:logs": "node scripts/validate-logs.mjs",
    "check:local": "npm run test:ui-logic && npm run harness:test && npm run check:logs",
    "check:verify": "npm run check:local && npm run build && npm run package",
    "harness:run": "node harness/scripts/run-harness.mjs --config harness/config/harness.config.example.json --scenario harness/scenarios/dry-run.translation.json",
    "harness:test:positive": "node harness/tests/smoke.positive.mjs",
    "harness:test:negative": "node harness/tests/smoke.negative.mjs",
    "harness:test": "node harness/tests/smoke.mjs"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@playwright/test": "1.53.0",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "tsx": "4.20.6",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
    ]
  }
}
